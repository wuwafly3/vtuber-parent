# LLM (openai-compatible)
PET_LLM_BASE_URL=https://api.openai.com/v1
PET_LLM_API_KEY=sk-your-key-here
PET_LLM_MODEL=gpt-4o-mini

# DashScope 百炼 (TTS 声音克隆 + 合成)
PET_DASHSCOPE_API_KEY=sk-your-dashscope-key
PET_TTS_MODEL=cosyvoice-v2
PET_TTS_VOICE=longxiaochun_v2
PET_TTS_ENABLED=true

# 服务
PET_HOST=127.0.0.1
PET_PORT=8000

# Agent computer use: 安全开关
# readonly = 仅截屏, confirm = 操作前确认, off = 禁用 computer use
PET_COMPUTER_USE_MODE=confirm
